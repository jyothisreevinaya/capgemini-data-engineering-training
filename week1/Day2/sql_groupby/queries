#1 Total salary per department
SELECT department, SUM(salary) AS total_salary
FROM Employee
GROUP BY department;

#2 Count employees per department
SELECT department, COUNT(*) AS total_employees
FROM Employee
GROUP BY department;

#3 Average salary per department
SELECT department, AVG(salary) AS avg_salary
FROM Employee
GROUP BY department;

#4 Maximum salary per department
SELECT department, MAX(salary) AS max_salary
FROM Employee
GROUP BY department;

#5 Minimum salary per department
SELECT department, MIN(salary) AS min_salary
FROM Employee
GROUP BY department;

#6 Departments with total salary > 100000
SELECT department, SUM(salary) AS total_salary
FROM Employee
GROUP BY department
HAVING SUM(salary) > 100000;

#7 Departments with more than 2 employees
SELECT department, COUNT(*) AS total_employees
FROM Employee
GROUP BY department
HAVING COUNT(*) > 2;

#8 Avg salary after 2021 grouped by department
SELECT department, AVG(salary) AS avg_salary
FROM Employee
WHERE joining_date > '2021-01-01'
GROUP BY department;

#9 Departments where max salary > 75000
SELECT department, MAX(salary) AS max_salary
FROM Employee
GROUP BY department
HAVING MAX(salary) > 75000;

#10 Departments with total salary < 150000
SELECT department, SUM(salary) AS total_salary
FROM Employee
GROUP BY department
HAVING SUM(salary) < 150000;

#11 Departments with more than 1 employee
SELECT department, COUNT(*) AS total_employees
FROM Employee
GROUP BY department
HAVING COUNT(*) > 1;

#12 Departments with total salary > 125000
SELECT department, SUM(salary) AS total_salary
FROM Employee
GROUP BY department
HAVING SUM(salary) > 125000;

#13 Departments with more than 2 employees
SELECT department, COUNT(*) AS total_employees
FROM Employee
GROUP BY department
HAVING COUNT(*) > 2;

#14 Departments with avg salary > 60000
SELECT department, AVG(salary) AS avg_salary
FROM Employee
GROUP BY department
HAVING AVG(salary) > 60000;

#15 Departments with total salary between 100k and 200k
SELECT department, SUM(salary) AS total_salary
FROM Employee
GROUP BY department
HAVING SUM(salary) BETWEEN 100000 AND 200000;

#16 Total sales per employee
SELECT e.emp_id, e.emp_name, SUM(s.amount) AS total_sales
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_id, e.emp_name;

#17 Number of sales per employee
SELECT e.emp_id, e.emp_name, COUNT(s.sales_id) AS total_sales_count
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_id, e.emp_name;

#18 Total sales by product
SELECT product, SUM(amount) AS total_sales
FROM Sales
GROUP BY product;

#19 Average sales by product
SELECT product, AVG(amount) AS avg_sales
FROM Sales
GROUP BY product;

#20 Employees with more than 2 sales
SELECT e.emp_id, e.emp_name, COUNT(s.sales_id) AS total_sales
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_id, e.emp_name
HAVING COUNT(s.sales_id) > 2;

#21 Salary and total sales per employee
SELECT e.emp_id, e.emp_name, e.salary, SUM(s.amount) AS total_sales
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_id, e.emp_name, e.salary;

#22 Unique products sold per employee
SELECT e.emp_id, e.emp_name, COUNT(DISTINCT s.product) AS unique_products
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_id, e.emp_name;

#23 Highest sale per employee
SELECT e.emp_id, e.emp_name, MAX(s.amount) AS max_amount
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_id, e.emp_name;

#24 Products with total sales > 50000
SELECT product, SUM(amount) AS total_sales
FROM Sales
GROUP BY product
HAVING SUM(amount) > 50000;

#25 Department with highest average sales
SELECT department, avg_amount
FROM (
    SELECT e.department, AVG(s.amount) AS avg_amount
    FROM Employee e
    JOIN Sales s ON e.emp_id = s.emp_id
    GROUP BY e.department
) t
ORDER BY avg_amount DESC
LIMIT 1;

#26 Department with highest total sales
SELECT e.department, SUM(s.amount) AS total_sales
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.department
ORDER BY total_sales DESC
LIMIT 1;

#27 Top 3 employees by total sales
SELECT e.emp_name, SUM(s.amount) AS total_sales
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.emp_name
ORDER BY total_sales DESC
LIMIT 3;

#28 Employees count and avg salary by joining year
SELECT YEAR(joining_date) AS join_year,
       COUNT(*) AS total_employees,
       AVG(salary) AS avg_salary
FROM Employee
GROUP BY YEAR(joining_date);

#29 Total sales per department
SELECT e.department, SUM(s.amount) AS total_sales
FROM Employee e
JOIN Sales s ON e.emp_id = s.emp_id
GROUP BY e.department;

#30 Employees without sales by department
SELECT e.department, COUNT(e.emp_id) AS employees_without_sales
FROM Employee e
LEFT JOIN Sales s ON e.emp_id = s.emp_id
WHERE s.emp_id IS NULL
GROUP BY e.department;
